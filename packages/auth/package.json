{
  "name": "@zephyr/auth",
  "description": "Zephyr's authentication & email service package",
  "version": "1.0.7",
  "license": "AGPL-3.0",
  "private": true,
  "scripts": {
    "check-types": "tsc --noEmit"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    },
    "./validation": {
      "types": "./src/validation/index.ts",
      "default": "./src/validation/index.ts"
    }
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@zephyr/db": "workspace:*",
    "better-auth": "^1.6.5",
    "disposable-email-domains": "^1.0.62",
    "email-validator": "^2.0.4",
    "jose": "^6.2.2",
    "next": "^16.2.4",
    "node-email-verifier": "^3.4.1",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/disposable-email-domains": "^1.0.6",
    "@zephyr/config": "workspace:*",
    "bun-types": "^1.3.12",
    "typescript": "^6.0.3"
  }
}

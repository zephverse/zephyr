{
  "name": "zephyr",
  "version": "1.0.1",
  "license": "AGPL-3.0",
  "homepage": "https://zephyyrr.in",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo check-types && turbo dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "check-types": "turbo check-types",
    "postinstall": "bun run --filter=@zephyr/db db:generate",
    "db:gen": "bun run --filter=@zephyr/db generate",
    "db:push": "bun run --filter=@zephyr/db push",
    "db:up": "bun run --filter=@zephyr/db generate && bun run --filter=@zephyr/db push",
    "build": "turbo check-types && turbo build",
    "dep:check": "bunx sherif@latest -f",
    "search:init": "cd packages/db && bunx tsx scripts/init-meilisearch.ts",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yml --profile init --profile studio up -d",
    "docker:apps": "docker compose -f docker/docker-compose.dev.yml --profile apps up web auth docs -d --build",
    "docker:clean": "docker compose -f docker/docker-compose.dev.yml down -v && docker volume rm zephyr-dev-postgres-data zephyr-dev-redis-data zephyr-dev-minio-data zephyr-dev-redisinsight-data && rm -f .dev-init",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "meilisearch": "^0.54.0",
    "prisma": "^7.1.0",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "ultracite": "6.4.0"
  },
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "@tailwindcss/oxide",
    "@tsparticles/engine",
    "esbuild",
    "prisma",
    "sharp"
  ],
  "packageManager": "bun@1.3.4",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  }
}

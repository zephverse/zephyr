{
  "name": "zephyr",
  "version": "1.0.1",
  "license": "AGPL-3.0",
  "homepage": "https://zephyyrr.in",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo check-types && turbo dev",
    "check": "ultracite fix --unsafe",
    "check-types": "turbo check-types",
    "postinstall": "bun run --filter=@zephyr/db db:generate",
    "db:gen": "bun run --filter=@zephyr/db generate",
    "db:push": "bun run --filter=@zephyr/db push",
    "db:up": "bun run --filter=@zephyr/db generate && bun run --filter=@zephyr/db push",
    "build": "turbo check-types && turbo build",
    "dep:check": "bunx sherif -f",
    "search:init": "cd packages/db && bunx tsx scripts/init-meilisearch.ts",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yml --profile init --profile studio up -d",
    "docker:clean": "docker compose -f docker/docker-compose.dev.yml down -v && docker volume rm zephdev-postgres18-data zephdev-redis-data zephdev-zephob-data zephdev-redisinsight-data && rm -f .dev-init",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "meilisearch": "^0.54.0",
    "prisma": "^7.7.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.0"
  },
  "packageManager": "bun@1.3.12",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bunx ultracite fix"
    ]
  }
}
